# IqUp-Web — environment variables (TEMPLATE)
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must NEVER be committed.
#
# Where the values come from: Supabase dashboard → Project Settings → API.
# (The project was created in Phase 1.05-Cowork: ref `cpxssfodboukznzaksnb`,
#  region eu-central-1 / Frankfurt.)

# Public project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser. By design it can NEITHER
# read NOR write the `leads` table (RLS is enabled with no anon policies).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role secret key — SERVER ONLY. Bypasses Row Level Security, so it must
# never reach the browser bundle, never be committed, and live only here (and in
# Vercel's server-side env later). Used exclusively by src/lib/supabase/server.ts.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Results email — Brevo (Phase 2.01). SERVER ONLY (except NEXT_PUBLIC_SITE_URL).
# Cowork provides the values; until BREVO_API_KEY is set, the send is a logged
# no-op and the funnel runs normally. The branded @iqup.mk sender + SPF/DKIM/DMARC
# are finalised in 2.06; this dev sender is a Brevo-verified address.
#
# Phase 3.10's v2 REPORT email (the PDF cognitive-profile attachment) REUSES the
# same vars below — BREVO_API_KEY + EMAIL_FROM_ADDRESS (+ optional EMAIL_FROM_NAME /
# EMAIL_REPLY_TO). No new env. Same no-key → logged no-op behaviour.
# ---------------------------------------------------------------------------

# Brevo transactional API key (Brevo dashboard → SMTP & API → API Keys). SERVER ONLY.
BREVO_API_KEY=

# From address + display name on the results email. Must be a Brevo-verified sender.
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# Optional Reply-To (omit to reply to the From address).
EMAIL_REPLY_TO=

# Dev-only: where `npm run test:email` AND `npm run test:report-email` send their
# samples. A test inbox you own — NEVER a real parent. Both scripts refuse prod / CI.
TEST_EMAIL_TO=

# ---------------------------------------------------------------------------
# CRM contact routing + new-lead notification — Brevo (Phase 2.02). SERVER ONLY.
# Reuses BREVO_API_KEY + EMAIL_FROM_ADDRESS above (do NOT duplicate them — the same
# key powers the contact upsert and the notification). Until the values below land,
# each side-effect logs a no-op and the funnel is unaffected. Live verification
# waits for Cowork's Brevo setup — see the Phase 2.02 completion report's checklist.
# ---------------------------------------------------------------------------

# Integer id of the operational "all leads" Brevo list — EVERY successful lead is
# upserted here (team visibility / follow-up, NOT a marketing action). A missing or
# invalid value simply skips this list (the contact still upserts). SERVER ONLY.
BREVO_LEADS_LIST_ID=

# Integer id of the marketing / nurture Brevo list (the 2.03 follow-up sequences
# run on it). A lead is added here ONLY when it opted in to marketing — a non-opt-in
# lead is NEVER placed on this list. A missing/invalid value simply skips it. SERVER ONLY.
BREVO_MARKETING_LIST_ID=

# Internal recipient(s) for the new-lead notification — a central IqUp inbox or a
# distribution list (NOT a parent address). Comma-separated for several recipients.
# Unset → the notification is a logged no-op. SERVER ONLY.
LEAD_NOTIFY_TO=

# Optional: overrides EMAIL_FROM_ADDRESS as the From on the internal notification
# (must be a Brevo-verified sender). Omit to reuse EMAIL_FROM_ADDRESS. SERVER ONLY.
LEAD_NOTIFY_FROM=

# Absolute site URL for the email's trial-CTA link (and metadataBase). Falls back
# to http://localhost:3000 when unset; the production domain is set in 2.06.
NEXT_PUBLIC_SITE_URL=

# Real demo-class booking URL for the results screen's CTA (Phase 3.09). PUBLIC
# (ships in the browser bundle — not a secret). The CTA appends the chosen centre
# as `?grad=<centre-id>`. When UNSET, the CTA falls back to the localized `/trial`
# page (so it is never a dead link); set this to the real IqUp booking flow once it
# lands. Example: https://booking.iqup.mk/start
NEXT_PUBLIC_BOOKING_URL=

# ---------------------------------------------------------------------------
# Analytics, heatmaps & ad pixel — consent-gated (Phase 2.04). PUBLIC ids (they
# ship in the browser bundle — they are NOT secrets). Each tracker loads ONLY
# after the parent grants its consent category, AND only when its id below is
# set. Leave any of them unset → that tracker never loads and the cookie banner
# still works (graceful no-op). Cowork creates the accounts (2.04 second half).
# ---------------------------------------------------------------------------

# Google Analytics 4 measurement id (looks like G-XXXXXXXXXX). Analytics category.
NEXT_PUBLIC_GA4_ID=

# Microsoft Clarity project id (heatmaps / session recordings). Analytics category.
# NOTE: Cowork must also switch OFF Clarity's automatic cookies in the project's
# Advanced settings so it obeys the consentv2 signal this code sends.
NEXT_PUBLIC_CLARITY_ID=

# Meta (Facebook) Pixel / dataset id — ad measurement. Marketing category.
NEXT_PUBLIC_META_PIXEL_ID=
