# IqUp-Web — environment variables (TEMPLATE)
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must NEVER be committed.
#
# Where the values come from: Supabase dashboard → Project Settings → API.
# (The project was created in Phase 1.05-Cowork: ref `cpxssfodboukznzaksnb`,
#  region eu-central-1 / Frankfurt.)

# Public project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose to the browser. By design it can NEITHER
# read NOR write the `leads` table (RLS is enabled with no anon policies).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role secret key — SERVER ONLY. Bypasses Row Level Security, so it must
# never reach the browser bundle, never be committed, and live only here (and in
# Vercel's server-side env later). Used exclusively by src/lib/supabase/server.ts.
SUPABASE_SERVICE_ROLE_KEY=
