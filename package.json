{
  "name": "iqup-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "qa:screens": "playwright test tests/e2e/screenshots.spec.ts",
    "lhci:mobile": "lhci autorun --config=./lighthouserc.mobile.cjs",
    "lhci:desktop": "lhci autorun --config=./lighthouserc.desktop.cjs",
    "lh:median": "node scripts/lh-median.mjs",
    "db:push": "supabase db push --linked",
    "db:types": "supabase gen types --lang typescript --linked --schema public > src/lib/supabase/types.ts",
    "test:insert": "tsx --conditions=react-server scripts/test-insert.ts",
    "test:scores": "tsx --conditions=react-server scripts/test-anonymous-score.ts",
    "test:email": "tsx --tsconfig scripts/email-runtime/tsconfig.json scripts/test-email.ts",
    "emails:nurture": "tsx --tsconfig scripts/email-runtime/tsconfig.json scripts/render-nurture.mts"
  },
  "dependencies": {
    "@fontsource/nunito-sans": "5.2.7",
    "@fontsource/rubik": "^5.2.8",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@react-pdf/renderer": "4.5.1",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "html-to-image": "1.11.13",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "supabase": "^2.105.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
